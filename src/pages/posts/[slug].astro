---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => {
    return import.meta.env.PROD ? !data.draft : true;
  });
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const allPosts = await getCollection('posts', ({ data }) => {
  return import.meta.env.PROD ? !data.draft : true;
});
const sorted = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const currentIndex = sorted.findIndex(p => p.id === post.id);
const prevPost = sorted[currentIndex + 1] ?? null;
const nextPost = sorted[currentIndex - 1] ?? null;

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-GB', { day: '2-digit', month: 'short' }).toUpperCase();
}

function truncate(str: string, n: number): string {
  return str.length > n ? str.slice(0, n) + '…' : str;
}
---

<Base title={post.data.title}>
  <main>
    <a class="back" href="/">← back to writing</a>

    <p class="post-date">{formatDate(post.data.date)}</p>
    <h1 class="post-title">{post.data.title}</h1>

    <article class="prose">
      <Content />
    </article>

    <div class="post-nav">
      {prevPost ? (
        <a href={`/posts/${prevPost.id}`} class="nav-prev">← {formatDate(prevPost.data.date)} · {truncate(prevPost.data.title, 30)}</a>
      ) : <span />}
      {nextPost ? (
        <a href={`/posts/${nextPost.id}`} class="nav-next">{formatDate(nextPost.data.date)} · {truncate(nextPost.data.title, 30)} →</a>
      ) : <span />}
    </div>
  </main>
</Base>

<style>
  main {
    padding-bottom: 64px;
  }

  .back {
    display: inline-block;
    font-family: var(--mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--muted);
    margin-bottom: 56px;
    transition: color 0.15s;
  }

  .back:hover {
    color: var(--accent);
  }

  .post-date {
    font-family: var(--mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--muted);
    margin-bottom: 16px;
  }

  .post-title {
    font-family: var(--serif);
    font-size: 34px;
    font-weight: 500;
    line-height: 1.15;
    letter-spacing: -0.012em;
    margin-bottom: 48px;
  }

  /* Prose styles */
  .prose :global(p) {
    font-family: var(--serif);
    font-size: 17px;
    line-height: 1.7;
    margin-bottom: 1.1em;
  }

  .prose :global(h2) {
    font-family: var(--serif);
    font-size: 22px;
    font-weight: 500;
    line-height: 1.3;
    margin-top: 44px;
    margin-bottom: 16px;
  }

  .prose :global(h3) {
    font-family: var(--serif);
    font-size: 18px;
    font-weight: 500;
    margin-top: 32px;
    margin-bottom: 12px;
  }

  .prose :global(blockquote) {
    border-left: 2px solid var(--accent);
    padding-left: 20px;
    font-style: italic;
    color: var(--muted);
    margin: 1.6em 0;
  }

  .prose :global(blockquote p) {
    margin-bottom: 0;
  }

  .prose :global(a) {
    color: var(--text);
    border-bottom: 0.5px solid var(--subtle);
    transition: color 0.15s, border-color 0.15s;
  }

  .prose :global(a:hover) {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }

  .prose :global(code) {
    font-family: var(--mono);
    font-size: 14px;
    background: var(--code-bg);
    padding: 2px 6px;
    border-radius: 3px;
  }

  .prose :global(pre) {
    font-family: var(--mono);
    font-size: 13px;
    background: var(--code-bg);
    padding: 18px 20px;
    border-radius: 6px;
    line-height: 1.55;
    margin: 1.4em 0;
    overflow-x: auto;
  }

  .prose :global(pre code) {
    background: none;
    padding: 0;
    border-radius: 0;
    font-size: inherit;
  }

  .prose :global(ul),
  .prose :global(ol) {
    font-family: var(--serif);
    font-size: 17px;
    line-height: 1.7;
    padding-left: 22px;
    margin-bottom: 1.1em;
  }

  .prose :global(img) {
    width: 100%;
    border-radius: 4px;
    margin-top: 1.6em;
    margin-bottom: 6px;
  }

  .prose :global(img + em),
  .prose :global(img + p > em:only-child) {
    display: block;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.04em;
    font-style: normal;
    margin-bottom: 1.6em;
  }

  .prose :global(hr) {
    border: none;
    border-top: 0.5px solid var(--border);
    margin: 2.5em 0;
  }

  .post-nav {
    margin-top: 56px;
    padding-top: 24px;
    border-top: 0.5px solid var(--border);
    display: flex;
    justify-content: space-between;
    gap: 16px;
  }

  .post-nav a,
  .post-nav span {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.1em;
    transition: color 0.15s;
  }

  .post-nav a:hover {
    color: var(--accent);
  }

  .nav-next {
    text-align: right;
  }
</style>
